// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Category {
  BEER
  ENERGY
  OTHER
  SNACKS
  COFFEE_TEA
  CANNED
  GROCERY
  PET_SUPPLIES
  PRODUCE
}

enum PaymentMethod {
  CASH
  CARD
}

enum OrderStatus {
  NEW
  CONFIRMED
  DELIVERING
  DELIVERED
  CANCELLED
}

model Product {
  id            String      @id @default(cuid())
  name          String
  category      Category
  volumeMl      Int?
  weightGrams   Int?
  packCount     Int?
  caseSize      Int         @default(1)
  purchasePrice Decimal     @db.Decimal(10, 2)
  sellPrice     Decimal     @db.Decimal(10, 2)
  imageUrl      String?
  description   String?
  calories      Float?
  protein       Float?
  fat           Float?
  carbs         Float?
  // Для корма для животных (гарантированный анализ, % вместо ккал/г): используем те же
  // protein/fat, плюс отдельно клетчатку и влагу.
  fiber         Float?
  moisture      Float?
  inStock       Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  orderItems    OrderItem[]

  // Разные объёмы одного товара могут называться одинаково (объём — на бейдже, не в тексте) —
  // Prisma не даёт составной уникальный ключ с nullable-полем (volumeMl бывает null у весовых
  // товаров), поэтому уникальности на уровне БД нет; синк ищет совпадение по (name, volumeMl)
  // вручную (см. prisma/seed.ts).
  @@index([name])
  @@index([category])
}

model Order {
  id            String        @id @default(cuid())
  customerName  String
  phone         String
  address       String
  comment       String?
  paymentMethod PaymentMethod @default(CASH)
  status        OrderStatus   @default(NEW)
  ageConfirmed  Boolean       @default(false)
  isPickup      Boolean       @default(false)
  totalAmount   Decimal       @db.Decimal(10, 2)
  totalCost     Decimal       @db.Decimal(10, 2)
  totalProfit   Decimal       @db.Decimal(10, 2)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  items         OrderItem[]

  @@index([createdAt])
  @@index([status])
}

model OrderItem {
  id                String  @id @default(cuid())
  orderId           String
  order             Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId         String
  product           Product @relation(fields: [productId], references: [id])
  productName       String
  quantity          Int
  unitPurchasePrice Decimal @db.Decimal(10, 2)
  unitSellPrice     Decimal @db.Decimal(10, 2)

  @@index([orderId])
  @@index([productId])
}
